# ==========================================================================
# .env.example
# --------------------------------------------------------------------------
# Copie este arquivo para `.env` e preencha cada variavel com seus valores.
# NUNCA commite o `.env` com valores reais.
#
#     cp .env.example .env
#
# ==========================================================================

# --------------------------------------------------------------------------
# LLM
# --------------------------------------------------------------------------
# Chave da OpenAI. Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key

# Modelo principal do agente.
OPENAI_MODEL=gpt-5-mini

# Audio no WhatsApp e transcrito antes de chegar ao agente principal.
# Use gpt-4o-transcribe para mais qualidade, ou gpt-4o-mini-transcribe para menor custo.
OPENAI_AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_AUDIO_LANGUAGE=pt

# --------------------------------------------------------------------------
# Banco de dados (Postgres com pgvector)
# --------------------------------------------------------------------------
# LOCAL (docker compose): o compose.yaml ja preenche tudo automaticamente,
#   voce NAO precisa mudar nada aqui.
# PRODUCAO (Railway): preferencialmente use uma reference variable unica:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# Alternativa: use `reference variables` separadas do servico Postgres:
#   DB_HOST=${{Postgres.PGHOST}}
#   DB_PORT=${{Postgres.PGPORT}}
#   DB_USER=${{Postgres.PGUSER}}
#   DB_PASS=${{Postgres.PGPASSWORD}}
#   DB_DATABASE=${{Postgres.PGDATABASE}}
# DATABASE_URL=
DB_DRIVER=postgresql+psycopg
DB_HOST=db
DB_PORT=5432
DB_USER=ai
DB_PASS=ai
DB_DATABASE=ai
WAIT_FOR_DB=True

# --------------------------------------------------------------------------
# WhatsApp (Meta for Developers)
# --------------------------------------------------------------------------
# Deixe `WHATSAPP_ENABLED=false` ate preencher todas as 4 credenciais abaixo
# e abrir o tunel NGrok (desenvolvimento) ou configurar o dominio Railway
# (producao).
#
# Obter em: https://developers.facebook.com -> seu App -> WhatsApp -> API Setup
#
# IMPORTANTE: use token permanente gerado via System User
# (business.facebook.com -> Configuracoes -> Usuarios do sistema). O token
# temporario de 24h que aparece em "API Setup" so serve para teste rapido.
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# Invente qualquer string secreta aqui. Voce vai colar o MESMO valor no
# Meta ao configurar o webhook (em "Verify token").
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# App Secret do seu app Meta. Obter em:
# developers.facebook.com -> App -> Configuracoes -> Basico -> App Secret
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# --------------------------------------------------------------------------
# Servidor
# --------------------------------------------------------------------------
PORT=8000

# Nunca `True` em producao. Se for `True`, tokens viram logs em texto puro.
PRINT_ENV_ON_LOAD=False

# --------------------------------------------------------------------------
# Opcional
# --------------------------------------------------------------------------
# `dev` habilita auto-reload do uvicorn.
# RUNTIME_ENV=dev

# CORS: se o seu frontend consome o AgentOS, liste aqui os origins permitidos
# separados por virgula. Deixe vazio se so usa a UI embutida.
# CORS_ALLOW_ORIGINS=https://meu-frontend.com,https://outro.com
